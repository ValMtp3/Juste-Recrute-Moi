{
  "name": "juste-recrute-moi",
  "private": true,
  "version": "1.2.5",
  "description": "Agrégateur local-first d'offres d'emploi pour le marché français.",
  "packageManager": "pnpm@10.33.2",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/ValMtp3/Juste-Recrute-Moi.git"
  },
  "bugs": {
    "url": "https://github.com/ValMtp3/Juste-Recrute-Moi/issues"
  },
  "homepage": "https://github.com/ValMtp3/Juste-Recrute-Moi#readme",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "setup:local": "node scripts/setup-local-runtime.mjs",
    "clean:generated": "node scripts/clean-generated.mjs",
    "clean:generated:dry": "node scripts/clean-generated.mjs --dry-run",
    "clean:generated:deps": "node scripts/clean-generated.mjs --include-deps",
    "dev:local": "node scripts/setup-local-runtime.mjs && pnpm tauri dev",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:behavioral": "vitest run src/features/behavioralRender.test.tsx",
    "test:coverage": "vitest run --coverage --exclude src/features/behavioralRender.test.tsx",
    "build": "node scripts/build-frontend.mjs",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "build:runtime-pack": "node scripts/package-runtime-pack.mjs",
    "stage:runtime-pack": "node scripts/stage-runtime-pack.mjs",
    "build:vector-runtime": "node scripts/package-vector-runtime.mjs",
    "build:all": "node scripts/run-parallel.mjs build:all",
    "release:verify-updater": "node scripts/verify-updater-release.mjs",
    "release:preflight": "pnpm check:all && pnpm release:smoke",
    "version:bump": "node scripts/version.mjs bump",
    "version:check": "node scripts/version.mjs check",
    "check": "pnpm check:all",
    "check:all": "node scripts/run-parallel.mjs check:all",
    "preview": "vite preview",
    "tauri": "tauri",
    "smoke:sidecar": "node scripts/smoke-sidecar.mjs",
    "smoke:windows-update": "node scripts/smoke-windows-update.mjs",
    "smoke:live-sources": "node scripts/smoke-live-sources.mjs",
    "smoke:llm-cli": "node scripts/smoke-llm-cli.mjs",
    "release:smoke": "node scripts/run-parallel.mjs release:smoke && cd src-tauri && cargo build --release && cd .. && pnpm smoke:sidecar",
    "release": "pnpm release:windows",
    "release:windows": "pnpm version:check && pnpm build && pnpm build:sidecar && pnpm build:runtime-pack && pnpm package:windows",
    "release:linux": "pnpm version:check && pnpm build && pnpm build:sidecar && pnpm build:runtime-pack && pnpm package:linux",
    "release:macos": "pnpm version:check && pnpm build && pnpm build:sidecar && pnpm build:runtime-pack && pnpm package:macos",
    "package:fast": "pnpm release:smoke",
    "package:windows": "tauri build --bundles nsis",
    "package:windows:all": "tauri build --bundles nsis msi",
    "package:windows:msi": "tauri build --bundles msi",
    "package:linux": "tauri build --bundles deb appimage",
    "package:macos": "tauri build --bundles app,dmg"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "d3-force": "^3.0.0",
    "framer-motion": "^12.42.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/d3-force": "^3.0.10",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.1",
    "vitest": "^4.1.7"
  }
}
