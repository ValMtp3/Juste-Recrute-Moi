# Environnement local de développement pour Juste Recrute Moi
#
# Copiez ce fichier vers .env seulement si vous avez besoin de variables
# d'environnement côté shell. Pour un usage normal, privilégiez les réglages
# de l'application desktop.
#
# Ne mettez jamais de vraies clés dans .env.example.

# Modèle local optionnel
OLLAMA_URL=http://localhost:11434/v1

# Fournisseurs LLM optionnels pour les tests backend locaux
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
MOONSHOT_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
CEREBRAS_API_KEY=
PERPLEXITY_API_KEY=
HUGGINGFACE_API_KEY=
HF_TOKEN=
NVIDIA_API_KEY=
COHERE_API_KEY=
SAMBANOVA_API_KEY=
DASHSCOPE_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=

# API France Travail Offres d'emploi
# Source stable prioritaire pour le marché français.
# Créez une application côté France Travail, puis renseignez l'identifiant et le secret.
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# Surcharges optionnelles pour tests/migrations API France Travail
FRANCE_TRAVAIL_TOKEN_URL=https://entreprise.francetravail.fr/connexion/oauth2/access_token?realm=/partenaire
FRANCE_TRAVAIL_SEARCH_URL=https://api.francetravail.io/partenaire/offresdemploi/v2/offres/search
FRANCE_TRAVAIL_SCOPE=api_offresdemploiv2 o2dsoffre

# X/Twitter est optionnel et désactivé sans bearer token.
X_BEARER_TOKEN=
TWITTER_BEARER_TOKEN=

# Connecteurs commerciaux facultatifs utilisés par certaines fonctions d'enrichissement.
HUNTER_API_KEY=
PROXYCURL_API_KEY=

# Laboratoire d'automatisation navigateur, désactivé par défaut.
JHM_AUTO_APPLY=false
PLAYWRIGHT_CHROMIUM_EXECUTABLE=

# Chemins locaux et logs, utiles surtout en développement, tests et packaging.
JHM_LOG_LEVEL=INFO
JHM_APP_DATA_BASE_DIR=
JHM_APP_DATA_DIR=
JHM_APP_VERSION=
JHM_RUNTIME_PACK_VERSION=
JHM_VECTOR_RUNTIME_DIR=
JHM_BROWSER_RUNTIME_DIR=
PLAYWRIGHT_BROWSERS_PATH=

# Runtime packs optionnels. Laissez vide pour utiliser les artefacts GitHub de release.
JHM_RUNTIME_PACK_URL=
JHM_BUNDLED_RUNTIME_PACK_URL=
JHM_RELEASE_RUNTIME_PACK_URL=
JHM_VECTOR_RUNTIME_URL=
JHM_BROWSER_RUNTIME_URL=

# Diagnostics locaux opt-in. Ne pas activer dans un environnement public sans revue.
JHM_LOCAL_ERROR_TELEMETRY=false
JHM_ERRORS_JSONL=

# Tests live opt-in, désactivés par défaut.
JHM_LIVE_CLI=false
JHM_LIVE_BROWSER=false
JHM_PORTFOLIO_LLM=true
JHM_CODEX_REASONING=low
CLAUDE_CODE_OAUTH_TOKEN=

# Smoke tests et packaging avancé. À laisser vide sauf si vous lancez les scripts dédiés.
JHM_LIVE_SOURCE_SMOKE=false
JHM_LIVE_SOURCE_ROLE=
JHM_LIVE_SOURCE_TIMEOUT_MS=60000
JHM_LIVE_ATS_TARGET=
JHM_WINDOWS_UPDATE_SMOKE=false
JHM_WINDOWS_INSTALLER_SMOKE=false
JHM_WINDOWS_UPDATE_TIMEOUT_MS=120000
JHM_WINDOWS_INSTALLER_TIMEOUT_MS=120000
JHM_SIDECAR_SMOKE_TIMEOUT_MS=120000
JHM_SMOKE_RUNTIME_PACK_ARCHIVE=
JHM_SIDECAR_PATH=
JHM_SIDECAR_CWD=
JHM_VECTOR_RUNTIME_REQUIRED=false
JHM_EXPECTED_VERSION=
JHM_MACOS_CODESIGN_IDENTITY=
JHM_RELEASE_FEATURES=

# Site public / Vercel. À renseigner seulement dans l'environnement de déploiement du site.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
VIEW_COUNT_BASELINE=0
DOWNLOAD_COUNT_BASELINE=0
COUNTER_WRITES_ENABLED=true
COUNTER_SERVER_CACHE_SECONDS=1800
COUNTER_CDN_CACHE_SECONDS=21600
COUNTER_VISITOR_TTL_DAYS=400
COUNTER_HASH_SALT=
GITHUB_FEEDBACK_TOKEN=
GITHUB_FEEDBACK_REPO=ValMtp3/Juste-Recrute-Moi
GITHUB_TOKEN=
